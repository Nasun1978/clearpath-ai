# ============================================================================
# ClearPath AI — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================================

# Supabase Configuration
# Get these from: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic Claude API
# Get this from: console.anthropic.com > API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ClearPath AI

# Optional: Document Processing
# DOCPARSER_API_KEY=your-docparser-key
# AWS_ACCESS_KEY_ID=your-aws-key (for Textract)
# AWS_SECRET_ACCESS_KEY=your-aws-secret

# Optional: Email (for notifications)
# RESEND_API_KEY=your-resend-key
# EMAIL_FROM=notifications@clearpath-ai.com

# Field-Level Encryption (AES-256-GCM, per-user HKDF key derivation)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Add to Vercel: Settings → Environment Variables → ENCRYPTION_MASTER_KEY
ENCRYPTION_MASTER_KEY=your-64-hex-char-key-here
